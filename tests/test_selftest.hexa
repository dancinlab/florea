#!hexa strict
// tests/test_selftest.hexa — 7-verb spec-presence harness

fn main() {
    let root = env("FLOREA_ROOT")
    let mut p = "cli/florea.hexa"
    if root.len() > 0 { p = root + "/cli/florea.hexa" }

    let raw = exec("FLOREA_ROOT=" + root + " hexa run " + p + " selftest 2>&1")
    if raw.contains("__FLOREA_SELFTEST__ PASS") == false {
        println("test_selftest: FAIL (sentinel missing)")
        println(raw.trim())
        exit(1)
    }
    if raw.contains("total verbs: 7") == false {
        println("test_selftest: FAIL (verb count != 7)")
        exit(1)
    }
    if raw.contains("present:     7/7") == false {
        println("test_selftest: FAIL (presence != 7/7)")
        exit(1)
    }
    println("test_selftest: PASS — 7/7 cosmetic·aesthetic·skincare·perfumery verb specs present")
}
